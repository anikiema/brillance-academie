{
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    { "source": "/api/:path*",          "destination": "/api/:path*" },
    { "source": "/app",                 "destination": "/app.html" },
    { "source": "/app/:path*",          "destination": "/app.html" },
    { "source": "/(.*)",                "destination": "/index.html" }
  ]
}
